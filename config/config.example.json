{
  "telegram": {
    "bot_token": "TELEGRAM_BOT_TOKEN",
    "allowed_chat_ids": [
      0
    ],
    "attachments": {
      "max_files": 10
    }
  },
  "jira": {
    "base_url": "https://your-domain.atlassian.net",
    "email": "user@company.com",
    "api_token": "JIRA_API_TOKEN",
    "project_key": "ABC",
    "issue_type_id": "10009",
    "subtask_issue_type_id": "10010",
    "attachment_max_bytes": 10485760
  },
  "due": {
    "notification": {
      "window_days": 3,
      "report_timezone": "Asia/Ho_Chi_Minh",
      "report_times": [
        "08:00",
        "17:00"
      ]
    }
  },
  "conversation": {
    "timeout_minutes": 10,
    "reminder_after_minutes": 5
  },
  "llm": {
    "enabled": true,
    "timeout_seconds": 20,
    "prompts": {
      "encourage_poem_path": "config/prompts/encourage_poem_lucbat.md"
    },
    "gemini": {
      "base_url": "https://generativelanguage.googleapis.com",
      "api_version": "v1beta",
      "model": "gemini-2.0-flash",
      "api_key": "GEMINI_API_KEY"
    }
  }
}

